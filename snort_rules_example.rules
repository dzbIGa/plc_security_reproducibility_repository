# Publication-safe IDS examples
alert tcp any any -> any 102 (msg:"Potential S7comm replay burst"; flow:to_server,established; detection_filter:track by_src,count 10,seconds 5; sid:1000001; rev:1;)
alert tcp any any -> any 80 (msg:"Repeated PLC HTTP authentication attempts"; flow:to_server,established; detection_filter:track by_src,count 15,seconds 10; sid:1000002; rev:1;)
alert tcp any any -> any 443 (msg:"Repeated PLC HTTPS authentication attempts"; flow:to_server,established; detection_filter:track by_src,count 15,seconds 10; sid:1000003; rev:1;)
